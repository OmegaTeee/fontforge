{
  "mcpServers": {
    "fontforge": {
      "type": "stdio",
      "command": "/Users/visualval/fontforge/venv/bin/python",
      "args": [
        "/Users/visualval/fontforge/mcp-server/server.py"
      ]
    },
    "serena": {
      "name": "Serena",
      "type": "stdio",
      "command": "/opt/homebrew/bin/uvx",
